{
  "name": "template-goblin-ui",
  "version": "0.1.0",
  "description": "Visual template builder for TemplateGoblin — design PDF templates with drag-and-drop",
  "type": "module",
  "bin": {
    "template-goblin-ui": "./bin/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "jszip": "^3.10.1",
    "konva": "^9.3.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@template-goblin/types": "workspace:*",
    "template-goblin": "workspace:*",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.4"
  },
  "comment:jszip": "ZIP read/write for .tgbl files in browser",
  "comment:konva": "Canvas rendering engine for react-konva",
  "comment:react-konva": "React bindings for Konva — drag-and-drop canvas",
  "comment:zustand": "Lightweight state management — canvas state, undo/redo, UI state"
}
