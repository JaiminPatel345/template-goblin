{
  "name": "@template-goblin/types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for TemplateGoblin — template schema, input JSON, errors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.2"
  }
}
